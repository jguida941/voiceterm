{
  "schema_version": 1,
  "repo_name": "VoiceTerm",
  "extends": [
    "quality_presets/voiceterm.json"
  ],
  "capabilities": {
    "python": true,
    "rust": true
  },
  "repo_governance": {
    "check_router": {
      "bundle_by_lane": {
        "docs": "bundle.docs",
        "runtime": "bundle.runtime",
        "tooling": "bundle.tooling",
        "release": "bundle.release"
      },
      "release_exact_paths": [
        "rust/Cargo.toml",
        "rust/Cargo.lock",
        "pypi/pyproject.toml",
        "app/macos/VoiceTerm.app/Contents/Info.plist"
      ],
      "release_workflow_files": [
        "release_preflight.yml",
        "publish_pypi.yml",
        "publish_homebrew.yml",
        "publish_release_binaries.yml",
        "release_attestation.yml"
      ],
      "tooling_exact_paths": [
        "AGENTS.md",
        "Makefile",
        "dev/ARCHITECTURE.md",
        "dev/DEVELOPMENT.md",
        "dev/MCP_DEVCTL_ALIGNMENT.md",
        "dev/guides/DEVELOPMENT.md",
        "dev/guides/ARCHITECTURE.md",
        "dev/guides/DEVCTL_AUTOGUIDE.md",
        "dev/guides/MCP_DEVCTL_ALIGNMENT.md",
        "dev/scripts/README.md",
        "dev/DEVCTL_AUTOGUIDE.md",
        "dev/history/ENGINEERING_EVOLUTION.md"
      ],
      "tooling_prefixes": [
        "dev/scripts/",
        ".github/workflows/",
        ".github/scripts/",
        "scripts/macro-packs/"
      ],
      "tooling_markdown_prefixes": [
        "dev/active/",
        "dev/config/"
      ],
      "runtime_prefixes": [
        "rust/src/",
        "rust/tests/",
        "rust/benches/"
      ],
      "runtime_exact_paths": [
        "rust/Cargo.toml",
        "rust/Cargo.lock",
        "rust/clippy.toml"
      ],
      "docs_prefixes": [
        "guides/",
        "img/",
        "docs/"
      ],
      "docs_exact_paths": [
        "README.md",
        "QUICK_START.md",
        "dev/README.md",
        "scripts/README.md",
        "pypi/README.md",
        "app/README.md"
      ],
      "risk_addons": [
        {
          "id": "overlay-hud-controls",
          "label": "Overlay/input/status/HUD add-ons",
          "tokens": [
            "/hud/",
            "/status_line/",
            "/overlay",
            "/input/",
            "rust/src/bin/voiceterm/config/cli.rs",
            "rust/src/config/mod.rs"
          ],
          "commands": [
            "python3 dev/scripts/devctl.py check --profile ci",
            "cd rust && cargo test --bin voiceterm",
            "python3 dev/scripts/devctl.py check --profile quick --skip-fmt --skip-clippy --no-parallel"
          ]
        },
        {
          "id": "performance-latency",
          "label": "Performance/latency add-ons",
          "tokens": [
            "latency",
            "perf",
            "/event_loop/",
            "voice_benchmark",
            "/audio/"
          ],
          "commands": [
            "python3 dev/scripts/devctl.py check --profile prepush",
            "./dev/scripts/tests/measure_latency.sh --voice-only --synthetic",
            "./dev/scripts/tests/measure_latency.sh --ci-guard",
            "python3 dev/scripts/devctl.py process-cleanup --verify --format md"
          ]
        },
        {
          "id": "wake-word",
          "label": "Wake-word add-ons",
          "tokens": [
            "wake_word",
            "voice_control/navigation",
            "voice_control/manager"
          ],
          "commands": [
            "bash dev/scripts/tests/wake_word_guard.sh",
            "python3 dev/scripts/devctl.py check --profile release",
            "python3 dev/scripts/devctl.py process-cleanup --verify --format md"
          ]
        },
        {
          "id": "threading-lifecycle-memory",
          "label": "Threading/lifecycle/memory add-ons",
          "tokens": [
            "pty_session",
            "terminal_restore",
            "/event_loop/",
            "memory_guard"
          ],
          "commands": [
            "cd rust && cargo test --no-default-features legacy_tui::tests::memory_guard_backend_threads_drop -- --nocapture",
            "python3 dev/scripts/devctl.py check --profile quick --skip-fmt --skip-clippy --no-parallel"
          ]
        },
        {
          "id": "unsafe-ffi-lifecycle",
          "label": "Unsafe/FFI lifecycle add-ons",
          "tokens": [
            "pty_session",
            "terminal_restore",
            "rust/src/stt.rs"
          ],
          "commands": [
            "cd rust && cargo test pty_session::tests::pty_cli_session_drop_terminates_descendants_in_process_group -- --nocapture",
            "cd rust && cargo test pty_session::tests::pty_overlay_session_drop_terminates_descendants_in_process_group -- --nocapture",
            "cd rust && cargo test stt::tests::transcriber_restores_stderr_after_failed_model_load -- --nocapture",
            "python3 dev/scripts/devctl.py check --profile quick --skip-fmt --skip-clippy --no-parallel"
          ]
        },
        {
          "id": "parser-ansi-boundary",
          "label": "Parser/ANSI boundary add-ons",
          "tokens": [
            "/ansi",
            "/parser",
            "prompt/strip",
            "pty_session"
          ],
          "commands": [
            "cd rust && cargo test pty_session::tests::prop_find_csi_sequence_respects_bounds -- --nocapture",
            "cd rust && cargo test pty_session::tests::prop_find_osc_terminator_respects_bounds -- --nocapture",
            "cd rust && cargo test pty_session::tests::prop_split_incomplete_escape_preserves_original_bytes -- --nocapture",
            "python3 dev/scripts/devctl.py check --profile quick --skip-fmt --skip-clippy --no-parallel"
          ]
        },
        {
          "id": "dependency-security",
          "label": "Dependency/security-hardening add-ons",
          "tokens": [
            "Cargo.toml",
            "Cargo.lock",
            "pyproject.toml",
            "requirements",
            "dev/security/",
            "security_guard.yml"
          ],
          "commands": [
            "python3 dev/scripts/devctl.py security"
          ]
        }
      ]
    },
    "push": {
      "default_remote": "origin",
      "development_branch": "develop",
      "release_branch": "master",
      "protected_branches": [
        "develop",
        "master"
      ],
      "allowed_branch_prefixes": [
        "feature/",
        "fix/"
      ],
      "preflight": {
        "command": "check-router",
        "since_ref_template": "{remote}/{development_branch}",
        "execute": true
      },
      "bypass": {
        "allow_skip_preflight": false,
        "allow_skip_post_push": false
      },
      "checkpoint": {
        "max_dirty_paths_before_checkpoint": 12,
        "max_untracked_paths_before_checkpoint": 6,
        "compatibility_projection_paths": ["bridge.md"],
        "advisory_context_paths": ["convo.md"]
      },
      "post_push": {
        "bundle": "bundle.post-push"
      }
    },
    "docs_check": {
      "user_docs": [
        "README.md",
        "QUICK_START.md",
        "guides/USAGE.md",
        "guides/CLI_FLAGS.md",
        "guides/INSTALL.md",
        "guides/TROUBLESHOOTING.md"
      ],
      "tooling_change_prefixes": [
        "dev/scripts/",
        "scripts/macro-packs/",
        ".github/workflows/"
      ],
      "tooling_change_exact": [
        "Makefile",
        "AGENTS.md",
        "dev/DEVELOPMENT.md",
        "dev/guides/DEVELOPMENT.md",
        "dev/scripts/README.md"
      ],
      "tooling_required_docs": [
        "AGENTS.md",
        "dev/guides/DEVELOPMENT.md",
        "dev/scripts/README.md",
        "dev/active/MASTER_PLAN.md"
      ],
      "tooling_required_doc_aliases": {},
      "tooling_doc_requirement_rules": [
        {
          "id": "ai_governance_platform_plan",
          "trigger_prefixes": [
            "dev/scripts/devctl/platform/",
            "dev/scripts/devctl/runtime/",
            "dev/scripts/devctl/quality_policy",
            "dev/scripts/devctl/governance/",
            "dev/scripts/devctl/governance_",
            "dev/scripts/devctl/commands/platform_",
            "dev/scripts/devctl/commands/governance_",
            "dev/scripts/checks/package_layout/"
          ],
          "trigger_exact_paths": [
            "dev/config/devctl_repo_policy.json",
            "dev/scripts/devctl/repo_policy.py",
            "dev/scripts/checks/probe_compatibility_shims.py",
            "dev/active/portable_code_governance.md",
            "dev/guides/PORTABLE_CODE_GOVERNANCE.md",
            "dev/active/ai_governance_platform.md",
            "dev/guides/AI_GOVERNANCE_PLATFORM.md"
          ],
          "required_docs": [
            "dev/active/ai_governance_platform.md"
          ]
        }
      ],
      "guide_contract_rules": [
        {
          "id": "devctl_autoguide_system_surface",
          "doc_path": "dev/guides/DEVCTL_AUTOGUIDE.md",
          "required_contains": [
            "AGENTS.md",
            "dev/guides/DEVELOPMENT.md",
            "dev/guides/AGENT_COLLABORATION_SYSTEM.md",
            "dev/scripts/README.md",
            "check_guide_contract_sync.py",
            "## System Coverage Map"
          ]
          ,
          "required_sections": [
            {
              "heading": "System Coverage Map",
              "required_contains": [
                "render-surfaces",
                "quality-policy",
                "platform-contracts",
                "probe-report",
                "governance-export",
                "governance-bootstrap",
                "governance-import-findings",
                "governance-review",
                "review-channel",
                "tandem-validate",
                "reviewer-heartbeat",
                "reviewer-checkpoint",
                "swarm_run",
                "mobile-status",
                "phone-status",
                "controller-action",
                "orchestrate-status",
                "orchestrate-watch",
                "integrations-sync",
                "integrations-import",
                "mcp",
                "launcher-check",
                "launcher-probes",
                "launcher-policy",
                "publication-sync",
                "release-notes",
                "compat-matrix",
                "mutants",
                "loop-packet",
                "mobile-app",
                "ralph-status",
                "failure-cleanup",
                "cihub-setup",
                "path-audit",
                "path-rewrite"
              ]
            }
          ]
        },
        {
          "id": "agents_push_workflow_surface",
          "doc_path": "AGENTS.md",
          "required_contains": [
            "python3 dev/scripts/devctl.py startup-context --format md",
            "python3 dev/scripts/devctl.py push --execute",
            "await_checkpoint",
            "await_review",
            "run_devctl_push",
            "no_push_needed"
          ]
        },
        {
          "id": "development_push_workflow_surface",
          "doc_path": "dev/guides/DEVELOPMENT.md",
          "required_contains": [
            "python3 dev/scripts/devctl.py startup-context --format md",
            "python3 dev/scripts/devctl.py push --execute",
            "reviewer-checkpoint",
            "await_checkpoint",
            "await_review",
            "run_devctl_push",
            "no_push_needed"
          ]
        },
        {
          "id": "scripts_readme_push_workflow_surface",
          "doc_path": "dev/scripts/README.md",
          "required_contains": [
            "python3 dev/scripts/devctl.py startup-context --format md",
            "python3 dev/scripts/devctl.py push --execute",
            "reviewer-checkpoint",
            "await_checkpoint",
            "await_review",
            "run_devctl_push",
            "no_push_needed"
          ]
        },
        {
          "id": "portable_push_workflow_surface",
          "doc_path": "dev/guides/PORTABLE_CODE_GOVERNANCE.md",
          "required_contains": [
            "repo_governance.push",
            "python3 dev/scripts/devctl.py startup-context --format md",
            "push_decision",
            "python3 dev/scripts/devctl.py push --execute",
            "post-commit /",
            "pre-push hook stubs"
          ]
        },
        {
          "id": "portable_push_workflow_template",
          "doc_path": "dev/config/templates/portable_governance_repo_setup.template.md",
          "required_contains": [
            "repo_governance.push",
            "python3 dev/scripts/devctl.py startup-context --format md",
            "push_decision",
            "python3 dev/scripts/devctl.py push --execute",
            "post-commit"
          ]
        }
      ],
      "evolution_doc": "dev/history/ENGINEERING_EVOLUTION.md",
      "evolution_change_prefixes": [
        "dev/scripts/",
        ".github/workflows/"
      ],
      "evolution_change_exact": [
        "AGENTS.md",
        "dev/ARCHITECTURE.md",
        "dev/DEVELOPMENT.md",
        "dev/guides/ARCHITECTURE.md",
        "dev/guides/DEVELOPMENT.md",
        "dev/scripts/README.md",
        "dev/active/MASTER_PLAN.md"
      ],
      "deprecated_reference_targets": [
        "AGENTS.md",
        "dev/DEVELOPMENT.md",
        "dev/guides/DEVELOPMENT.md",
        "dev/scripts/README.md",
        "scripts/macro-packs/full-dev.yaml",
        "Makefile"
      ],
      "deprecated_reference_patterns": [
        {
          "name": "release-script",
          "regex": "\\./dev/scripts/release\\.sh\\b",
          "replacement": "python3 dev/scripts/devctl.py release --version <version>"
        },
        {
          "name": "homebrew-script",
          "regex": "\\./dev/scripts/update-homebrew\\.sh\\b",
          "replacement": "python3 dev/scripts/devctl.py homebrew --version <version>"
        },
        {
          "name": "pypi-script",
          "regex": "\\./dev/scripts/publish-pypi\\.sh\\b",
          "replacement": "python3 dev/scripts/devctl.py pypi --upload"
        },
        {
          "name": "notes-script",
          "regex": "\\./dev/scripts/generate-release-notes\\.sh\\b",
          "replacement": "python3 dev/scripts/devctl.py release-notes --version <version>"
        }
      ]
    },
    "surface_generation": {
      "repo_pack_metadata": {
        "pack_id": "voiceterm",
        "pack_version": "0.1.0-dev",
        "product_name": "VoiceTerm",
        "repo_name": "codex-voice"
      },
      "context": {
        "process_doc": "AGENTS.md",
        "execution_tracker_doc": "dev/active/MASTER_PLAN.md",
        "active_registry_doc": "dev/active/INDEX.md",
        "architecture_doc": "dev/guides/AI_GOVERNANCE_PLATFORM.md",
        "development_doc": "dev/guides/DEVELOPMENT.md",
        "scripts_readme_doc": "dev/scripts/README.md",
        "shared_backlog_doc": "backlog.md",
        "ci_workflows_doc": ".github/workflows/README.md",
        "cli_flags_doc": "rust/src/bin/voiceterm/config/cli.rs",
        "project_summary": "Rust voice-first terminal overlay for AI CLIs (Codex, Claude, Gemini)",
        "rust_source": "rust/src/bin/voiceterm/",
        "python_tooling": "dev/scripts/devctl/",
        "guard_scripts": "dev/scripts/checks/",
        "msrv": "1.88.0, edition 2021",
        "branch_policy": "`master` (release), `develop` (dev work)",
        "voice_command": "voiceterm --capture-once --format text",
        "development_branch": "develop",
        "python_version": "3.11",
        "post_edit_verification_intro": "After EVERY file create/edit, you MUST run the repo-required verification before reporting the task as done.",
        "post_edit_verification_done_criteria": "Done means the required guards/tests passed. Do not report completion after only writing code or running a partial subset of checks. If a required guard fails, fix it or report the blocker explicitly.",
        "user_preferences_block": "- Comments must be forward-looking and useful — never reference past refactoring\n- No duplicated logic — extract shared helpers\n- If a file exceeds soft limit, modularize it (don't trim comments)\n- Get to solid stopping points for Codex review\n- Explain things at junior-to-mid level (user is an architect learning Rust)\n- Don't write dumb comments nobody will understand in the future"
      },
      "surfaces": [
        {
          "id": "agents_bundle_reference",
          "surface_type": "process_doc",
          "renderer": "agents_bundle_section",
          "output_path": "AGENTS.md",
          "tracked": true,
          "local_only": false,
          "description": "Rendered AGENTS command-bundle reference section."
        },
        {
          "id": "claude_instructions",
          "surface_type": "local_instructions",
          "renderer": "template_file",
          "template_path": "dev/config/templates/claude_instructions.template.md",
          "output_path": "CLAUDE.md",
          "tracked": false,
          "local_only": true,
          "description": "Local-only Claude instructions surface rendered from repo-pack policy.",
          "required_contains": [
            "## Task Router Quick Map",
            "## Checkpoint / Review / Push Contract",
            "## Mandatory post-edit verification (blocking)",
            "After EVERY file create/edit, you MUST run the repo-required verification before",
            "Done means the required guards/tests passed.",
            "Run the task-class bundle from `AGENTS.md` after every file create/edit:",
            "python3 dev/scripts/devctl.py probe-report --format md",
            "python3 dev/scripts/devctl.py push --execute",
            "Treat `push_decision` as the canonical next remote-action state machine:"
          ]
        },
        {
          "id": "codex_voice_slash",
          "surface_type": "assistant_template",
          "renderer": "template_file",
          "template_path": "dev/config/templates/codex_voice_slash.template.md",
          "output_path": "dev/templates/slash/codex/voice.md",
          "tracked": true,
          "local_only": false,
          "description": "Slash-command template for one-shot VoiceTerm capture in Codex."
        },
        {
          "id": "claude_voice_skill",
          "surface_type": "assistant_template",
          "renderer": "template_file",
          "template_path": "dev/config/templates/claude_voice_skill.template.md",
          "output_path": "dev/templates/slash/claude/SKILL.md",
          "tracked": true,
          "local_only": false,
          "description": "Claude skill template for one-shot VoiceTerm capture."
        },
        {
          "id": "portable_pre_commit_hook_stub",
          "surface_type": "starter_artifact",
          "renderer": "template_file",
          "template_path": "dev/config/templates/portable_governance_pre_commit_hook.stub.template.sh",
          "output_path": "dev/config/templates/portable_governance_pre_commit_hook.stub.sh",
          "tracked": true,
          "local_only": false,
          "description": "Generated starter pre-commit hook stub for governance adopters."
        },
        {
          "id": "portable_post_commit_hook_stub",
          "surface_type": "starter_artifact",
          "renderer": "template_file",
          "template_path": "dev/config/templates/portable_governance_post_commit_hook.stub.template.sh",
          "output_path": "dev/config/templates/portable_governance_post_commit_hook.stub.sh",
          "tracked": true,
          "local_only": false,
          "description": "Generated starter post-commit hook stub for governance adopters."
        },
        {
          "id": "portable_pre_push_hook_stub",
          "surface_type": "starter_artifact",
          "renderer": "template_file",
          "template_path": "dev/config/templates/portable_governance_pre_push_hook.stub.template.sh",
          "output_path": "dev/config/templates/portable_governance_pre_push_hook.stub.sh",
          "tracked": true,
          "local_only": false,
          "description": "Generated starter pre-push hook stub for governance adopters."
        },
        {
          "id": "portable_tooling_workflow_stub",
          "surface_type": "starter_artifact",
          "renderer": "template_file",
          "template_path": "dev/config/templates/portable_governance_tooling_workflow.stub.template.yml",
          "output_path": "dev/config/templates/portable_governance_tooling_workflow.stub.yml",
          "tracked": true,
          "local_only": false,
          "description": "Generated starter tooling workflow stub for governance adopters."
        }
      ]
    }
  },
  "quality_scopes": {
    "python_guard_roots": [
      "dev/scripts",
      "app/operator_console"
    ],
    "python_probe_roots": [
      "dev/scripts/devctl",
      "app/operator_console"
    ],
    "rust_guard_roots": [
      "rust/src"
    ],
      "rust_probe_roots": [
      "rust/src"
    ]
  },
  "protocol_boundary": {
    "rust_daemon_types": "rust/src/bin/voiceterm/daemon/types.rs",
    "swift_relay_models": "app/ios/VoiceTermMobile/Sources/VoiceTermMobileCore/MobileRelayModels.swift",
    "swift_daemon_models": "app/ios/VoiceTermMobile/Sources/VoiceTermMobileCore/DaemonWebSocketClient.swift",
    "python_daemon_reducer": "dev/scripts/devctl/review_channel/daemon_reducer.py",
    "name_map": {
      "AgentInfo": "AgentSnapshot"
    },
    "swift_computed_properties": ["id", "isOutput", "isError"]
  },
  "ai_guard_overrides": {
    "ide_provider_isolation": {
      "extra_args": [
        "--fail-on-violations"
      ]
    },
    "rust_lint_debt": {
      "extra_args": [
        "--report-dead-code",
        "--dead-code-report-limit",
        "120"
      ]
    }
  }
}
